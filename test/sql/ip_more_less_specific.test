# name: test/sql/ip_more_less_specific.test
# name: test/sql/ip_more_less_specific.test
# description: test ip more/less specific extension
# group: [ip]

# Before we load the extension, this will fail
statement error
SELECT riswhois_longest_prefix('240.0.0.0/4');
----
Catalog Error: Scalar Function with name riswhois_longest_prefix does not exist!

# Require statement will ensure the extension is loaded from now on
require ip_more_less_specific

require icu

# Confirm the extension works
query I
SELECT riswhois_longest_prefix('8.8.8.8');
----
8.8.8.0/24
